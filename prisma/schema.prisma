// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum EntryStatus {
  DRAFT
  POSTED
}

enum JournalEntryType {
  GENERAL
  RECEIPT
  PAYMENT
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  DECEASED
}

model Currency {
  id           String  @id @default(uuid())
  code         String  @unique // e.g., SAR, USD
  name         String
  symbol       String
  isBase       Boolean @default(false)
  exchangeRate Decimal @default(1) // Price relative to base currency

  branches     Branch[]
  history      CurrencyRateHistory[]
  accounts     Account[]
  journalLines JournalLine[]
  entities     Entity[]
}

model CurrencyRateHistory {
  id         String   @id @default(uuid())
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])
  rate       Decimal
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([currencyId, date])
}

model Branch {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  accounts       Account[]
  journalEntries JournalEntry[]
  entities       Entity[]
  users          User[]         @relation("BranchUsers")
}

model Entity {
  id                 String   @id @default(uuid())
  name               String
  code               String?  @unique
  currencyId         String
  currency           Currency @relation(fields: [currencyId], references: [id])
  userId             String?
  personInCharge     User?    @relation(fields: [userId], references: [id])
  annualSubscription Decimal  @default(0)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  members   Member[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id              String       @id @default(uuid())
  name            String
  entityId        String
  entity          Entity       @relation(fields: [entityId], references: [id])
  affiliationYear Int
  status          MemberStatus @default(ACTIVE)
  stoppedAt       DateTime?
  createdAt       DateTime     @default(now())

  subscriptions               MemberSubscription[]
  subscriptionCollectionItems SubscriptionCollectionItem[]
}

model MemberSubscription {
  id             String       @id @default(uuid())
  memberId       String
  member         Member       @relation(fields: [memberId], references: [id])
  year           Int
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  amount         Decimal

  @@unique([memberId, year])
}

model Account {
  id         String      @id @default(uuid())
  branchId   String
  branch     Branch      @relation(fields: [branchId], references: [id])
  name       String
  code       String      @unique
  type       AccountType
  currencyId String
  currency   Currency    @relation(fields: [currencyId], references: [id])
  parentId   String?
  parent     Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children   Account[]   @relation("AccountHierarchy")

  journalLines JournalLine[]
}

model JournalEntry {
  id          String           @id @default(uuid())
  branchId    String
  branch      Branch           @relation(fields: [branchId], references: [id])
  entryNumber Int?
  type        JournalEntryType @default(GENERAL)
  date        DateTime         @default(now())
  description String?
  totalAmount Decimal          @default(0)
  status      EntryStatus      @default(DRAFT)
  createdBy   String
  user        User             @relation(fields: [createdBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  lines                  JournalLine[]
  memberSubscriptions    MemberSubscription[]
  subscriptionCollection SubscriptionCollection?
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  currencyId     String
  currency       Currency     @relation(fields: [currencyId], references: [id])

  debit        Decimal @default(0)
  credit       Decimal @default(0)
  exchangeRate Decimal @default(1)

  baseDebit  Decimal @default(0)
  baseCredit Decimal @default(0)
}

model User {
  id                      String                   @id @default(uuid())
  username                String                   @unique
  password                String
  name                    String?
  role                    String                   @default("USER")
  journalEntries          JournalEntry[]
  auditLogs               AuditLog[]
  branches                Branch[]                 @relation("BranchUsers")
  entities                Entity[]
  subscriptionCollections SubscriptionCollection[]
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())
}

model Period {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isLocked  Boolean  @default(false)
}

model SubscriptionCollection {
  id     String      @id @default(uuid())
  number Int?
  date   DateTime    @default(now())
  status EntryStatus @default(DRAFT)

  description String?
  totalAmount Decimal @default(0)

  // Voucher info (optional in DRAFT)
  branchId        String?
  debitAccountId  String?
  creditAccountId String?
  journalEntryId  String?       @unique
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items SubscriptionCollectionItem[]
}

model SubscriptionCollectionItem {
  id           String                 @id @default(uuid())
  collectionId String
  collection   SubscriptionCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  memberId     String
  member       Member                 @relation(fields: [memberId], references: [id])
  year         Int
  amount       Decimal
}
